# =============================================================================
# Keystone Environment Configuration Example
# Copy this file to .env and fill in your values before running.
# NEVER commit .env to version control.
# =============================================================================

# PostgreSQL connection settings
DB_HOST=db
DB_PORT=5432
DB_NAME=keystone
DB_USER=keystone
DB_PASSWORD=keystone_pass

# JWT signing secret — must be at least 32 characters of random entropy
JWT_SECRET=your_jwt_secret_here_minimum_32_characters

# AES-256 encryption key — must be exactly 32 bytes (256 bits)
AES_KEY=your_aes_256_key_here_32_bytes!!

# Application ports
PORT=8080
FRONTEND_PORT=3000

# TOTP/MFA configuration
TOTP_ISSUER=Keystone

# Document storage path inside the backend container
DOCUMENTS_PATH=/app/documents
